# Anthropic (Kyo - Asistente virtual)
# Saca la key en https://console.anthropic.com > Settings > API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Opcional: override del modelo. Default: claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-6

# SMTP — Envio de correos (formulario de aplicacion a vacantes)
# Datos de tu cuenta de correo corporativo (Hostinger, cPanel, etc.)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contacto@kyoszen.com
SMTP_PASS=tu-contraseña-aqui

# Supabase - Phase 2 CRM (pendiente)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
